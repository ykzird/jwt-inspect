{
  "name": "@ykzird/jwt-inspect",
  "version": "1.0.1",
  "description": "CLI tool and library for decoding and security-auditing JWT tokens",
  "license": "MIT",
  "author": "ykzird",
  "keywords": ["jwt", "json-web-token", "cli", "security", "audit", "decode", "inspect"],
  "engines": { "node": ">=18" },
  "repository": {
    "type": "git",
    "url": "https://github.com/ykzird/jwt-inspect"
  },
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "require": "./dist/lib.js",
      "default": "./dist/lib.js"
    }
  },
  "bin": {
    "jwt-inspect": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
